{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python Debugger: Flask",
			"type": "debugpy",
			"request": "launch",
			"module": "flask",
			"env": {
				"FLASK_APP": "app.py",
				"FLASK_DEBUG": "1",
				"FLASK_RUN_HOST": "http://127.0.0.1",
				"FLASK_RUN_PORT": "5000"
			},
			"args": [
				"run",
				"--no-debugger",
				"--no-reload",
				"--port=5000",
				"--host=http://127.0.0.1"
			],
			"python": "./venv/bin/python",
			"jinja": true,
			"autoStartBrowser": false
		}
	]
}