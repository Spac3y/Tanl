{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Flask App",
			"type": "debugpy",
			"request": "launch",
			"module": "flask",
			"env": {
				"FLASK_APP": "app.py",
				"FLASK_DEBUG": "1",
				"FLASK_RUN_HOST": "https://127.0.0.1",
				"FLASK_RUN_PORT": "5000",
				"FLASK_ENV": "development"
			},
			"args": [
				"run",
				"--no-reload",
				"--port=5000",
				"--host=https://127.0.0.1"
			],
			"python": "./.venv/bin/python",
			"jinja": true,
			"autoStartBrowser": false,
			"cwd" : "${workspaceFolder}",
		}
	]
}